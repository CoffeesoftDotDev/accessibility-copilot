name: Pull request review issues creation
on: 
  pull_request:
    types: [ready_for_review]
  issues:
    types: [opened, edited]

permissions:
  issues: write
  contents: read
  models: read
  pull-requests: read

jobs:
  generate_tasks:
    runs-on: ubuntu-latest
    outputs: 
      reports: ${{ steps.pr_report_details.outputs.reports }}
      issues: ${{ steps.gen_issues.outputs.issues }}
      repo: ${{ steps.get_context.outputs.repo }}
    env:
      GH_TOKEN: ${{ github.token }}
    steps:
      - name: Checkout
        uses: actions/checkout@v3

      - name: Get Context
        id: get_context
        run: |-
          echo "repo=${{github.repository}}" >> "$GITHUB_OUTPUT"
          echo "$GITHUB_CONTEXT"
        env:
          GITHUB_CONTEXT: ${{ toJson(github) }}

      - name: Install gh-models extension
        run: gh extension install https://github.com/github/gh-models

      - name: Get PR report details
        if: contains(join(github.event.pull_request.labels.*.name, ','), 'neurodiversity-check')
        id: pr_report_details
        run: |-
          set -euo pipefail
          ISSUE_NB="${{ github.event.pull_request.number || github.event.issue.number }}"
          if [ -z "$ISSUE_NB" ]; then
            echo "Aucun numéro d'issue/PR détecté."
            {
              echo 'reports<<EOF'
              echo '[]'
              echo 'EOF'
            } >> "$GITHUB_OUTPUT"
            exit 0
          fi

            # Checkout PR head
          gh pr checkout "$ISSUE_NB"

          shopt -s nullglob
          files=(reports/*.md)
          if (( ${#files[@]} == 0 )); then
            {
              echo 'reports<<EOF'
              echo '[]'
              echo 'EOF'
            } >> "$GITHUB_OUTPUT"
            exit 0
          fi

          tmp=()
          for f in "${files[@]}"; do
            content=$(jq -R -s '.' < "$f")   # JSON string
            tmp+=( "$content" )
          done
          reports="[$(IFS=,; echo "${tmp[*]}")]"
          {
            echo 'reports<<EOF'
            echo "$reports"
            echo 'EOF'
          } >> "$GITHUB_OUTPUT"

      - name: Generate Issue Descriptions
        if: contains(join(github.event.pull_request.labels.*.name, ','), 'neurodiversity-check')
        id: gen_issues
        env:
          PROMPTS_FILE: .github/prompts/issue-split.prompt.yml
          REPO: ${{ steps.get_context.outputs.repo }}
          REPORTS: ${{ steps.pr_report_details.outputs.reports }}
        run: |-
          set -euo pipefail

          : "${REPORTS:?Missing REPORTS (reports JSON array)}"
          : "${PROMPTS_FILE:?Missing PROMPTS_FILE}"
          : "${REPO:?Missing REPO}"

          echo "Collecting repo labels..."
          labels="$(gh label list --repo "$REPO" --json name,description || echo '[]')"

          # Validation du format: tableau de chaînes
            jq -e 'type=="array" and all(.[]; type=="string")' <<<"$REPORTS" >/dev/null || {
            echo "REPORTS doit être un tableau JSON de chaînes."
            {
              echo 'issues<<EOF'
              echo '[]'
              echo 'EOF'
            } >> "$GITHUB_OUTPUT"
            exit 0
          }

          issues_fragments=()
          index=0

          # Boucle sur chaque markdown (protégé via base64)
          while IFS= read -r b64; do
            index=$((index+1))
            CONTENT=$(printf '%s' "$b64" | base64 -d)

            echo "---- Chunk #$index (taille: $(printf '%s' "$CONTENT" | wc -c) octets) ----"

            # Appel modèle
            if ! printf '%s' "$CONTENT" | gh models run \
                  --file "$PROMPTS_FILE" \
                  --var labels="$labels" > issues.json 2>model.stderr; then
              echo "⚠️ Échec modèle (chunk #$index)"
              sed 's/^/[stderr] /' model.stderr || true
              continue
            fi

            echo "Sortie brute:"
            sed 's/^/  /' issues.json

            # Normalisation:
            # - si .issues array -> garder
            # - si .issues objet -> en array
            # - si racine array -> supposer que c'est directement la liste d'issues
            # - sinon -> ignorer
            if jq -e '.issues? or (type=="array")' issues.json >/dev/null 2>&1; then
              norm=$(jq -c '
                if .issues? then
                  if .issues|type=="array" then .issues
                  elif .issues|type=="object" then [ .issues ]
                  else []
                  end
                elif type=="array" then .
                else []
                end
              ' issues.json)
              if [ "$norm" != "[]" ]; then
                issues_fragments+=( "$norm" )
              else
                echo "ℹ️ Aucune issue structurée trouvée dans ce chunk."
              fi
            else
              echo "ℹ️ Pas de champ .issues ni array racine — ignoré."
            fi

          done < <(jq -r '.[] | @base64' <<<"$REPORTS")

          # Agrégation
          if ((${#issues_fragments[@]}==0)); then
            merged='[]'
          else
            merged=$(printf '%s\n' "${issues_fragments[@]}" | jq -s 'add')
          fi

          echo "Nombre total d'issues agrégées: $(jq 'length' <<<"$merged")"

          {
            echo 'issues<<EOF'
            echo "$merged"
            echo 'EOF'
          } >> "$GITHUB_OUTPUT"

  add_to_backlog:
    needs: generate_tasks
    if: ${{ needs.test_action.outputs.issues != '' }}
    runs-on: ubuntu-latest
    strategy:
      max-parallel: 3
      fail-fast: false
      matrix:
        issue: ${{ fromJson(needs.test_action.outputs.issues) }}
    steps:
      - name: Create GitHub Issue
        env:
          GH_TOKEN: ${{ github.token }}
          ISSUE: ${{ toJson(matrix.issue) }}
          REPO: ${{ needs.test_action.outputs.repo }}
        run: |
          echo "Raw ISSUE:"
          echo "$ISSUE"
          title="$(echo "$ISSUE" | jq -r '.title // empty')"
          body="$(echo "$ISSUE" | jq -r '.body // empty')"
          label="$(echo "$ISSUE" | jq -r '.label // empty')"
          repo="$REPO"

          if [[ -z "$title" || -z "$body" ]]; then
            echo "Skipping invalid issue (missing title/body)"
            exit 0
          fi

          echo "Creating issue: $title (label=$label)"

          gh issue create \
            --title "$title" \
            --body "$body" \
            $( [ -n "$label" ] && printf -- '--label %q ' "$label" ) \
            --repo "$repo"
